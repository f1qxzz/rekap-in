NODE_ENV=development
PORT=8080
API_BASE_URL=http://localhost:8080
DATABASE_URL=postgresql://attendance:attendance@localhost:5432/attendance?schema=public
REDIS_URL=redis://localhost:6379

JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nCHANGE_ME\n-----END PRIVATE KEY-----"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\nCHANGE_ME\n-----END PUBLIC KEY-----"
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=7

APP_ENCRYPTION_KEY_BASE64=CHANGE_ME_32_BYTES_BASE64
ATTENDANCE_RATE_LIMIT_PER_MINUTE=10
OFFLINE_QUEUE_LIMIT=5

STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=./storage/private
S3_REGION=ap-southeast-1
S3_BUCKET=private-attendance-photos
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
SIGNED_URL_TTL_SECONDS=3600

FCM_SERVER_KEY=
FCM_SEND_URL=https://fcm.googleapis.com/fcm/send
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Absensi <no-reply@example.com>"
PAYROLL_WEBHOOK_URL=
PAYROLL_WEBHOOK_SECRET=
