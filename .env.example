# Backend
NODE_ENV=development
PORT=8080
API_BASE_URL=http://localhost:8080/api

# Local docker-compose services
DATABASE_URL=postgresql://attendance:attendance@localhost:5432/attendance?schema=public
REDIS_URL=redis://localhost:6379

# JWT keys. Leave CHANGE_ME for local development; production must use real PEM keys.
JWT_PRIVATE_KEY=CHANGE_ME
JWT_PUBLIC_KEY=CHANGE_ME
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_DAYS=7

# Security
APP_ENCRYPTION_KEY_BASE64=CHANGE_ME_32_BYTES_BASE64
ATTENDANCE_RATE_LIMIT_PER_MINUTE=10
OFFLINE_QUEUE_LIMIT=5

# Storage
STORAGE_PROVIDER=local
LOCAL_STORAGE_DIR=./storage/private
SIGNED_URL_TTL_SECONDS=3600

# Optional S3 / MinIO
S3_REGION=ap-southeast-1
S3_BUCKET=
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Notifications / email / payroll
FCM_SERVER_KEY=
FCM_SEND_URL=https://fcm.googleapis.com/fcm/send
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Absensi <no-reply@example.com>"
PAYROLL_WEBHOOK_URL=
PAYROLL_WEBHOOK_SECRET=
